<Window x:Class="KnockingTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:KnockingTool.Models"
        xmlns:conv="clr-namespace:KnockingTool.Converters"
        mc:Ignorable="d"
        Title="Knocking Tool"
        Icon="/Assets/app.ico"
        Height="820" Width="1180"
        MinHeight="700" MinWidth="960"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackgroundBrush}"
        FontFamily="Segoe UI">
    <Window.Resources>
        <conv:IntStringConverter x:Key="IntString" />
        <conv:ProtocolPortEnabledConverter x:Key="ProtocolPortEnabled" />

        <DataTemplate x:Key="NodeItemTemplate">
            <StackPanel>
                <TextBlock Text="{Binding Name}"
                           FontWeight="SemiBold"
                           FontSize="14"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
                <TextBlock Text="{Binding DestinationIp}"
                           FontSize="12"
                           Margin="0,4,0,0"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="260" />
            <RowDefinition Height="160" MinHeight="120" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderGradientBrush}" Padding="24,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="42" Height="42" CornerRadius="12" Background="#33FFFFFF" Margin="0,0,14,0">
                            <TextBlock Text="⬡" FontSize="22" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Knocking Tool" FontSize="24" FontWeight="Bold" Foreground="White" />
                            <TextBlock Text="ابزار ناکینگ چندمرحله‌ای ICMP / TCP / UDP"
                                       FontSize="13" Foreground="#E0E7FF" Margin="0,4,0,0" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="ThemeToggleButton"
                            Style="{StaticResource IconButton}"
                            Content="🌙"
                            ToolTip="تغییر تم"
                            Click="ThemeToggleButton_Click"
                            Background="#22FFFFFF"
                            Foreground="White"
                            BorderThickness="0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Update banner -->
        <Border x:Name="UpdateBanner"
                Grid.Row="1"
                Visibility="Collapsed"
                Background="{DynamicResource AccentBrush}"
                Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="UpdateBannerTitle"
                               Text="نسخه جدید در دسترس است"
                               FontWeight="SemiBold"
                               FontSize="14"
                               Foreground="White" />
                    <TextBlock x:Name="UpdateBannerSubtitle"
                               FontSize="12"
                               Foreground="#E0E7FF"
                               Margin="0,4,0,0"
                               TextWrapping="Wrap" />
                    <ProgressBar x:Name="UpdateProgressBar"
                                   Height="6"
                                   Margin="0,8,24,0"
                                   Visibility="Collapsed"
                                   Minimum="0"
                                   Maximum="1"
                                   Foreground="White"
                                   Background="#33FFFFFF" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="DownloadUpdateButton"
                            Content="دانلود نسخه جدید"
                            Click="DownloadUpdate_Click"
                            Padding="14,8"
                            Margin="0,0,8,0"
                            Background="White"
                            Foreground="{DynamicResource AccentBrush}"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Cursor="Hand" />
                    <Button x:Name="DismissUpdateButton"
                            Content="بعداً"
                            Click="DismissUpdate_Click"
                            Padding="14,8"
                            Style="{StaticResource SecondaryButton}"
                            Background="#22FFFFFF"
                            Foreground="White"
                            BorderBrush="#44FFFFFF" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content -->
        <Grid Grid.Row="2" Margin="20,16,20,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Nodes sidebar -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Padding="16">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
                        <TextBlock Text="نودها" Style="{StaticResource SectionTitle}" Margin="0,0,0,12" />
                        <UniformGrid Columns="2">
                            <Button Content="+ نود جدید" Click="AddNode_Click" Style="{StaticResource ModernButton}" Margin="0,0,4,0" />
                            <Button Content="حذف" Click="DeleteNode_Click" Style="{StaticResource DangerButton}" Margin="4,0,0,0" />
                        </UniformGrid>
                    </StackPanel>

                    <ListBox x:Name="NodesListBox"
                             ItemTemplate="{StaticResource NodeItemTemplate}"
                             Style="{StaticResource ModernListBox}"
                             SelectionChanged="NodesListBox_SelectionChanged" />
                </DockPanel>
            </Border>

            <!-- Node editor -->
            <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" MinHeight="150" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="تنظیمات نود" Style="{StaticResource SectionTitle}" Margin="0,0,0,16" />

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="نام نود" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="NodeNameTextBox"
                                     Style="{StaticResource ModernTextBox}"
                                     Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="IP مقصد" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="NodeIpTextBox"
                                     Style="{StaticResource ModernTextBox}"
                                     Text="{Binding DestinationIp, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,18,0,12">
                        <TextBlock Text="مراحل ناکینگ" Style="{StaticResource SectionTitle}" VerticalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="+ مرحله" Click="AddStep_Click" Style="{StaticResource ModernButton}" Padding="14,8" />
                            <Button Content="حذف مرحله" Click="DeleteStep_Click" Style="{StaticResource DangerButton}" Padding="14,8" />
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="3"
                            Background="{DynamicResource SurfaceMutedBrush}"
                            BorderBrush="{DynamicResource BorderBrushTheme}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="0"
                            MinHeight="150"
                            ClipToBounds="True">
                            <DataGrid x:Name="StepsDataGrid"
                                      Style="{StaticResource ModernDataGrid}"
                                      VerticalAlignment="Stretch"
                                      HorizontalAlignment="Stretch">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Order"
                                                        Binding="{Binding Order}"
                                                        Width="70"
                                                        MinWidth="60"
                                                        IsReadOnly="False">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridCellText}" />
                                        </DataGridTextColumn.ElementStyle>
                                        <DataGridTextColumn.EditingElementStyle>
                                            <Style TargetType="TextBox">
                                                <Setter Property="HorizontalContentAlignment" Value="Center" />
                                                <Setter Property="VerticalContentAlignment" Value="Center" />
                                                <Setter Property="Padding" Value="4,2" />
                                            </Style>
                                        </DataGridTextColumn.EditingElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridComboBoxColumn Header="Protocol"
                                                            SelectedItemBinding="{Binding Protocol, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="120"
                                                            MinWidth="100">
                                        <DataGridComboBoxColumn.ElementStyle>
                                            <Style TargetType="ComboBox">
                                                <Setter Property="ItemsSource">
                                                    <Setter.Value>
                                                        <x:Array Type="models:KnockProtocol">
                                                            <models:KnockProtocol>Icmp</models:KnockProtocol>
                                                            <models:KnockProtocol>Tcp</models:KnockProtocol>
                                                            <models:KnockProtocol>Udp</models:KnockProtocol>
                                                        </x:Array>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="VerticalContentAlignment" Value="Center" />
                                                <Setter Property="HorizontalContentAlignment" Value="Center" />
                                                <Setter Property="IsHitTestVisible" Value="False" />
                                                <Setter Property="Focusable" Value="False" />
                                            </Style>
                                        </DataGridComboBoxColumn.ElementStyle>
                                        <DataGridComboBoxColumn.EditingElementStyle>
                                            <Style TargetType="ComboBox">
                                                <Setter Property="ItemsSource">
                                                    <Setter.Value>
                                                        <x:Array Type="models:KnockProtocol">
                                                            <models:KnockProtocol>Icmp</models:KnockProtocol>
                                                            <models:KnockProtocol>Tcp</models:KnockProtocol>
                                                            <models:KnockProtocol>Udp</models:KnockProtocol>
                                                        </x:Array>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="VerticalContentAlignment" Value="Center" />
                                            </Style>
                                        </DataGridComboBoxColumn.EditingElementStyle>
                                    </DataGridComboBoxColumn>

                                    <DataGridTemplateColumn Header="Port" Width="90" MinWidth="80">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock>
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridCellText}">
                                                            <Setter Property="Text" Value="{Binding Port}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Protocol}" Value="Icmp">
                                                                    <Setter Property="Text" Value="—" />
                                                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                                                         IsEnabled="{Binding Protocol, Converter={StaticResource ProtocolPortEnabled}}"
                                                         HorizontalContentAlignment="Center"
                                                         VerticalContentAlignment="Center"
                                                         Padding="4,2" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTextColumn Header="Size"
                                                        Binding="{Binding PayloadSize}"
                                                        Width="90"
                                                        MinWidth="80">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridCellText}" />
                                        </DataGridTextColumn.ElementStyle>
                                        <DataGridTextColumn.EditingElementStyle>
                                            <Style TargetType="TextBox">
                                                <Setter Property="HorizontalContentAlignment" Value="Center" />
                                                <Setter Property="VerticalContentAlignment" Value="Center" />
                                            </Style>
                                        </DataGridTextColumn.EditingElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridCheckBoxColumn Header="Hdr 28B"
                                                            Binding="{Binding IncludeIpHeader, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="90"
                                                            MinWidth="80">
                                        <DataGridCheckBoxColumn.ElementStyle>
                                            <Style TargetType="CheckBox">
                                                <Setter Property="HorizontalAlignment" Value="Center" />
                                                <Setter Property="VerticalAlignment" Value="Center" />
                                            </Style>
                                        </DataGridCheckBoxColumn.ElementStyle>
                                    </DataGridCheckBoxColumn>

                                    <DataGridTextColumn Header="Delay"
                                                        Binding="{Binding DelayMs}"
                                                        Width="*"
                                                        MinWidth="90">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridCellText}" />
                                        </DataGridTextColumn.ElementStyle>
                                        <DataGridTextColumn.EditingElementStyle>
                                            <Style TargetType="TextBox">
                                                <Setter Property="HorizontalContentAlignment" Value="Center" />
                                                <Setter Property="VerticalContentAlignment" Value="Center" />
                                            </Style>
                                        </DataGridTextColumn.EditingElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                    </Border>

                    <TextBlock Grid.Row="4"
                               Style="{StaticResource HintText}"
                               Margin="0,12,0,0"
                               Text="ICMP: Size = payload, Hdr 28B = raw socket (IP+ICMP). TCP/UDP: set destination port." />
                </Grid>
            </Border>
        </Grid>

        <!-- Log panel -->
        <Border Grid.Row="3" Margin="20,12,20,0" Style="{StaticResource CardBorder}" Padding="12">
            <DockPanel>
                <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                    <TextBlock Text="لاگ اجرا" Style="{StaticResource SectionTitle}" VerticalAlignment="Center" />
                    <Button Content="پاک کردن"
                            HorizontalAlignment="Right"
                            Style="{StaticResource SecondaryButton}"
                            Padding="12,6"
                            Click="ClearLog_Click" />
                </Grid>
                <Border Background="{DynamicResource LogBackgroundBrush}"
                        CornerRadius="12"
                        Padding="10">
                    <TextBox x:Name="LogTextBox"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"
                             TextWrapping="Wrap"
                             FontFamily="Cascadia Mono, Consolas"
                             FontSize="12"
                             Background="Transparent"
                             Foreground="{DynamicResource LogForegroundBrush}"
                             BorderThickness="0" />
                </Border>
            </DockPanel>
        </Border>

        <!-- Footer actions -->
        <Border Grid.Row="4"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrushTheme}"
                BorderThickness="0,1,0,0"
                Padding="20,14">
            <Grid>
                <Border HorizontalAlignment="Left"
                        Background="{DynamicResource SurfaceMutedBrush}"
                        BorderBrush="{DynamicResource BorderBrushTheme}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="14,10"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="تکرار خودکار" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,12,0" />
                        <TextBlock Text="تعداد" Style="{StaticResource FieldLabel}" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBox x:Name="RepeatCountTextBox" Width="56" Margin="0,0,12,0"
                                 Style="{StaticResource ModernTextBox}" Padding="8,6"
                                 Text="{Binding Count, UpdateSourceTrigger=LostFocus, Converter={StaticResource IntString}}" />
                        <TextBlock Text="فاصله (ms)" Style="{StaticResource FieldLabel}" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBox x:Name="RepeatIntervalTextBox" Width="72"
                                 Style="{StaticResource ModernTextBox}" Padding="8,6"
                                 Text="{Binding IntervalMs, UpdateSourceTrigger=LostFocus, Converter={StaticResource IntString}}" />
                        <TextBlock Text="0 = بی‌نهایت" Style="{StaticResource HintText}"
                                   VerticalAlignment="Center" Margin="10,0,0,0" />
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="بارگذاری JSON" Style="{StaticResource SecondaryButton}" Click="LoadConfig_Click" />
                    <Button Content="ذخیره JSON" Style="{StaticResource SecondaryButton}" Click="SaveConfig_Click" />
                    <Button x:Name="StopButton" Content="توقف" Style="{StaticResource DangerButton}" Click="Stop_Click" IsEnabled="False" />
                    <Button x:Name="RunSelectedButton" Content="▶  اجرای نود" Style="{StaticResource ModernButton}" Click="RunSelectedNode_Click" />
                    <Button x:Name="RunAllButton" Content="▶▶  اجرای همه" Style="{StaticResource ModernButton}" Click="RunAllNodes_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Copyright -->
        <Border Grid.Row="5"
                Background="{DynamicResource AppBackgroundBrush}"
                Padding="0,0,0,10">
            <TextBlock Text="Design and Development by Hossein Zahedi"
                       FontSize="10"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       Opacity="0.75"
                       Cursor="Hand"
                       TextDecorations="Underline"
                       MouseLeftButtonUp="CopyrightLink_Click" />
        </Border>
    </Grid>
</Window>
